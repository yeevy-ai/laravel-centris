{
    "name": "yeevy/laravel-centris",
    "description": "Laravel wrapper for yeevy/centris-passerelle — unofficial client for the Centris® Passerelle FTP feed (Quebec MLS). Not affiliated with or endorsed by Centris or QFREB.",
    "keywords": [
        "yeevy",
        "laravel",
        "centris",
        "passerelle",
        "mls",
        "real-estate",
        "quebec",
        "immobilier"
    ],
    "homepage": "https://github.com/yeevy-ai/laravel-centris",
    "license": "MIT",
    "authors": [
        {
            "name": "Oleg Hmelevschi",
            "email": "info@digitalunity.ca",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.8",
        "illuminate/contracts": "^12.0||^13.0",
        "league/flysystem": "^3.0",
        "league/flysystem-ftp": "^3.0",
        "psr/event-dispatcher": "^1.0",
        "spatie/laravel-package-tools": "^1.16",
        "yeevy/centris-passerelle": "^0.2 || ^0.3"
    },
    "suggest": {
        "league/flysystem-sftp-v3": "Rebind the FeedSource contract with an SFTP-backed FlysystemFeedSource if your agreement uses SFTP."
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "orchestra/testbench": "^10.0||^11.0",
        "pestphp/pest": "^3.0||^4.0",
        "pestphp/pest-plugin-laravel": "^3.0||^4.0",
        "phpstan/extension-installer": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "Yeevy\\LaravelCentris\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Yeevy\\LaravelCentris\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse --no-progress --memory-limit=1G",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Yeevy\\LaravelCentris\\CentrisServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
